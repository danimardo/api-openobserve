# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── OpenObserve ──────────────────────────────────────────────────────────────
O2_URL=http://localhost:5080
O2_ORG=default
O2_AUTH_USER=root@example.com
O2_AUTH_PASSWORD=ChangeMe1234

# ─── API Keys ─────────────────────────────────────────────────────────────────
# Inline JSON array (use API_KEYS_FILE for production secrets)
API_KEYS_JSON=[{"id":"demo-key-001","secret_hash":"<sha256-hex-of-your-secret>","services":["payments_api"],"scopes":["write","read"],"client_type":"backend","allowed_origins":[],"envs":["dev"]}]
# API_KEYS_FILE=/run/secrets/api-keys.json

# ─── Allowed environments ─────────────────────────────────────────────────────
ALLOWED_ENVS=prod,staging,dev,test

# ─── Ingest limits ────────────────────────────────────────────────────────────
INGEST_MAX_BATCH=1000
INGEST_MAX_BODY_MB=5
LOG_MESSAGE_MAX_CHARS=8000
CONTEXT_MAX_DEPTH=2
CONTEXT_VALUE_MAX_CHARS=2000
MAX_FIELDS_PER_RECORD=200

# ─── Queue / delivery ─────────────────────────────────────────────────────────
QUEUE_MAX_ITEMS=10000
RETRY_ATTEMPTS=3
RETRY_BACKOFF_MS=200,1000,5000
DELIVERY_BATCH_MAX=500
DELIVERY_FLUSH_MS=1000

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_RPS=100

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Metrics ──────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
